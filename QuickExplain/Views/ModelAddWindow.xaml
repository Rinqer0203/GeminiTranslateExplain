<Window
    x:Class="QuickExplain.Views.ModelAddWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="モデル編集"
    Width="600"
    Height="460"
    MinWidth="560"
    MinHeight="420"
    ResizeMode="NoResize"
    Style="{StaticResource MaterialDesignWindow}"
    mc:Ignorable="d">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="40" />
            </Grid.ColumnDefinitions>

            <TextBox
                Grid.Column="0"
                Height="42"
                materialDesign:HintAssist.Hint="モデル名"
                Padding="10,7,10,4"
                Style="{StaticResource MaterialDesignOutlinedTextBox}"
                Text="{Binding ModelSearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

            <Button
                Grid.Column="1"
                Width="32"
                Height="32"
                Margin="8,5,0,0"
                Command="{Binding RefreshModelsCommand}"
                Style="{StaticResource MaterialDesignIconForegroundButton}"
                ToolTip="モデル一覧を再取得">
                <materialDesign:PackIcon
                    Width="18"
                    Height="18"
                    Kind="Refresh" />
            </Button>
        </Grid>

        <ProgressBar
            Grid.Row="1"
            Height="3"
            Margin="0,16,0,0"
            IsIndeterminate="{Binding IsLoading}" />

        <Grid Grid.Row="2" Margin="0,14,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border
                Grid.Row="0"
                MinHeight="56"
                Padding="10,8"
                Background="{DynamicResource MaterialDesignCardBackground}"
                BorderBrush="{DynamicResource MaterialDesignDivider}"
                BorderThickness="1">
                <TextBlock
                    FontSize="12"
                    LineHeight="18"
                    Text="{Binding StatusMessage}"
                    TextTrimming="CharacterEllipsis"
                    TextWrapping="Wrap" />
            </Border>

            <ListBox
                Grid.Row="1"
                Margin="0,12,0,0"
                BorderThickness="1"
                HorizontalContentAlignment="Stretch"
                ItemsSource="{Binding FilteredModels}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid MinHeight="42" Margin="4,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="40" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                Grid.Column="0"
                                Margin="4,0,12,0"
                                VerticalAlignment="Center"
                                FontSize="14"
                                FontWeight="SemiBold"
                                Text="{Binding Name}"
                                TextTrimming="CharacterEllipsis" />
                            <Border
                                Grid.Column="1"
                                MinWidth="64"
                                Margin="0,0,8,0"
                                Padding="8,3"
                                VerticalAlignment="Center"
                                Background="{DynamicResource MaterialDesignDivider}"
                                CornerRadius="3">
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    FontSize="11"
                                    Foreground="{DynamicResource MaterialDesignBody}"
                                    Text="{Binding ProviderName}" />
                            </Border>
                            <Button
                                x:Name="AddButton"
                                Grid.Column="2"
                                Width="32"
                                Height="32"
                                Command="{Binding AddCommand}"
                                Style="{StaticResource MaterialDesignIconForegroundButton}"
                                ToolTip="モデルを追加">
                                <materialDesign:PackIcon
                                    Width="18"
                                    Height="18"
                                    Kind="Plus" />
                            </Button>
                            <Button
                                x:Name="RemoveButton"
                                Grid.Column="2"
                                Width="32"
                                Height="32"
                                Command="{Binding RemoveCommand}"
                                Style="{StaticResource MaterialDesignIconForegroundButton}"
                                ToolTip="モデルを削除">
                                <materialDesign:PackIcon
                                    Width="18"
                                    Height="18"
                                    Kind="Delete" />
                            </Button>
                        </Grid>
                        <DataTemplate.Triggers>
                            <DataTrigger Binding="{Binding IsConfigured}" Value="True">
                                <Setter TargetName="AddButton" Property="Visibility" Value="Collapsed" />
                                <Setter TargetName="RemoveButton" Property="Visibility" Value="Visible" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsConfigured}" Value="False">
                                <Setter TargetName="AddButton" Property="Visibility" Value="Visible" />
                                <Setter TargetName="RemoveButton" Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>
    </Grid>
</Window>
